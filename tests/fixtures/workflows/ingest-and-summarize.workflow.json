{
  "schemaVersion": 1,
  "id": "ingest-and-summarize",
  "name": "Ingest and summarize",
  "nodes": [
    {
      "id": "trigger",
      "type": "trigger.manual",
      "position": { "x": 0, "y": 0 },
      "data": {}
    },
    {
      "id": "pick",
      "type": "file.pick",
      "position": { "x": 200, "y": 0 },
      "data": {}
    },
    {
      "id": "sub",
      "type": "workflow.subworkflow",
      "position": { "x": 400, "y": 0 },
      "data": {
        "workflowRef": "tests/fixtures/workflows/ingest-single-file.workflow.json",
        "inputMapping": {
          "path": "{{path}}",
          "wikiId": "{{wikiId}}"
        },
        "outputMapping": {
          "report": "ingestReport"
        }
      }
    },
    {
      "id": "summarize",
      "type": "llm.chat",
      "position": { "x": 600, "y": 0 },
      "data": {
        "user": "Summarize ingest with one sentence."
      }
    },
    {
      "id": "notice",
      "type": "output.notice",
      "position": { "x": 800, "y": 0 },
      "data": {
        "message": "{{summary}}"
      }
    }
  ],
  "edges": [
    { "id": "e1", "from": "trigger", "to": "pick" },
    { "id": "e2", "from": "pick", "to": "sub" },
    { "id": "e3", "from": "sub", "to": "summarize" },
    { "id": "e4", "from": "summarize", "to": "notice" }
  ]
}
